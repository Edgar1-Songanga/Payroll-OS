{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@magestade/database": ["packages/database/src"],
      "@magestade/api": ["packages/api/src"],
      "@magestade/auth": ["packages/auth/src"],
      "@magestade/payroll-os": ["packages/payroll-os/src"],
      "@magestade/types": ["packages/types/src"],
      "@magestade/utils": ["packages/utils/src"],
      "@/*": ["apps/web/src/*"]
    }
  }
}
